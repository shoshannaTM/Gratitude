{{>navbar}}

<main class="flex flex-col items-center gap-6 py-10 px-4 min-h-screen">

  {{#if user}}

    <p class="text-base-content/60 text-sm">{{todayFormatted}}</p>

    {{#if todayEntry}}

      {{! ── Already submitted today ── }}
      <div class="card bg-base-200 w-full max-w-md shadow">
        <div class="card-body items-center text-center gap-4">
          <div class="text-6xl">🙏</div>
          <h2 class="card-title text-2xl">Today's gratitudes</h2>
          <ol class="list-decimal list-inside space-y-2 text-left w-full">
            {{#each todayEntry.entries}}
            <li class="text-base-content/80">{{this}}</li>
            {{/each}}
          </ol>
          <p class="text-base-content/50 text-sm mt-2">Come back tomorrow!</p>
        </div>
      </div>

    {{else}}

      {{! ── Entry form ── }}
      <form action="/gratitude/submit" method="POST" class="w-full max-w-md">
        <input type="hidden" name="entryDate" value="{{today}}" />
        <fieldset class="fieldset bg-base-200 border-base-300 rounded-box border p-4 gap-2">
          <legend class="fieldset-legend text-lg">What are you grateful for today? 🙏</legend>

          {{#each inputSlots}}
          <label class="label">Gratitude {{this}}</label>
          <input
            class="input w-full"
            type="text"
            name="entries"
            placeholder="I am grateful for..."
            required
            {{#if (eq this 1)}}autofocus{{/if}}
          />
          {{/each}}

          <button class="btn btn-primary w-full mt-4" type="submit">
            Save today's gratitudes
          </button>
        </fieldset>
      </form>

    {{/if}}

  {{else if authEnabled}}

    {{! ── Not logged in ── }}
    <div class="hero min-h-[80vh]">
      <div class="hero-content text-center flex-col gap-6">
        <div class="text-7xl">🙏</div>
        <div>
          <h1 class="text-4xl font-bold mb-3">Your daily gratitude practice</h1>
          <p class="text-base-content/60 text-lg mb-8">
            Record what you're grateful for every day.<br/>
            Every Sunday, your words become a crossword puzzle.
          </p>
          <div class="flex gap-3 justify-center">
            <a href="/auth/register" class="btn btn-primary btn-lg">Get started</a>
            <a href="/auth/login" class="btn btn-ghost btn-lg">Sign in</a>
          </div>
        </div>
      </div>
    </div>

  {{else}}

    <div class="hero min-h-[80vh]">
      <div class="hero-content text-center">
        <div>
          <h1 class="text-4xl font-bold">Gratitude</h1>
          <p class="text-base-content/60 mt-4">
            Set <code>AUTH_ENABLED=true</code> in your environment to get started.
          </p>
        </div>
      </div>
    </div>

  {{/if}}

</main>

{{>dock}}
